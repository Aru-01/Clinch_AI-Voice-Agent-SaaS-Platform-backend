                  }
                ],
                "url": {
                  "raw": "{{base_url}}/api/crm/oauth-url/invalid/",
                  "host": ["{{base_url}}"],
                  "path": ["api", "crm", "oauth-url", "invalid", ""]
                }
              },
              "status": "Bad Request",
              "code": 400,
              "body": {
                "success": false,
                "error": "Unsupported CRM: invalid"
              }
            }
          ]
        },
        {
          "name": "OAuth Callback",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/crm/callback/{{crm_type}}/?code={{auth_code}}&state={{state}}",
              "host": ["{{base_url}}"],
              "path": ["api", "crm", "callback", "{{crm_type}}", ""],
              "query": [
                {
                  "key": "code",
                  "value": "{{auth_code}}"
                },
                {
                  "key": "state",
                  "value": "{{state}}"
                }
              ]
            },
            "description": "Handle OAuth callback from CRM provider\n\nParameters:\n- code: Authorization code from OAuth provider\n- state: State parameter for CSRF protection (from Get OAuth URL response)"
          },
          "response": [
            {
              "name": "Success",
