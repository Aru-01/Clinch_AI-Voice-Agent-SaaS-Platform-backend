    {
      "name": "Leads",
      "description": "Manage and list synced leads from CRM connections",
      "item": [
        {
          "name": "List Synced Leads",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/crm/leads/?crm_type={{crm_type}}&page={{page}}&page_size={{page_size}}",
              "host": ["{{base_url}}"],
              "path": ["api", "crm", "leads", ""],
              "query": [
                {
                  "key": "crm_type",
                  "value": "{{crm_type}}",
                  "disabled": true,
                  "description": "Filter by CRM type (optional): hubspot, salesforce, zoho, pipedrive, ghl"
                },
                {
                  "key": "page",
                  "value": "{{page}}",
                  "disabled": true,
                  "description": "Page number for pagination (default: 1)"
                },
                {
                  "key": "page_size",
                  "value": "{{page_size}}",
                  "disabled": true,
                  "description": "Number of items per page (default: 10)"
                }
              ]
            },
            "description": "Get paginated list of all synced leads for the authenticated user's business"
          },
          "response": [
            {
              "name": "Success",
              "originalRequest": {
                "method": "GET",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{access_token}}"
                  }
                ],
                "url": {
                  "raw": "{{base_url}}/api/crm/leads/?page=1&page_size=10",
                  "host": ["{{base_url}}"],
                  "path": ["api", "crm", "leads", ""],
                  "query": [
