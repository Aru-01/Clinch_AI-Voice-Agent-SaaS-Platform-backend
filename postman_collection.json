                  "path": ["api", "crm", "oauth-url", "hubspot", ""]
                }
              },
              "status": "OK",
              "code": 200,
              "body": {
                "success": true,
                "authorization_url": "https://app.hubspot.com/oauth/authorize?client_id=xxx&redirect_uri=xxx&state=uuid&scope=crm.objects.contacts.read",
